---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SectionReveal from '../components/SectionReveal.astro';

const eventTypes = [
  "Sunday Service",
  "Youth Night / Camp",
  "Conference",
  "Leadership Event",
  "School Assembly",
  "Athletic / FCA Event",
  "Other"
];

const speakingFocus = [
  "Spiritual growth / deeper faith",
  "Leadership & conviction",
  "Identity & purpose",
  "Overcoming adversity",
  "Athlete / team culture",
  "Open / led as needed"
];

const budgetRanges = [
  "Under $1,000",
  "$1,000 - $2,500",
  "$2,500 - $5,000",
  "$5,000+",
  "Not sure yet"
];
---

<BaseLayout title="Book Julian — Speaking Request">
  <Nav dark />

  <!-- ═══════════════ PAGE HERO ═══════════════ -->
  <section class="relative min-h-[50vh] flex items-end bg-black overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-orange/20 to-black"></div>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.04] overflow-hidden">
      <span class="text-[12rem] md:text-[20rem] font-display text-white whitespace-nowrap leading-none">INVITE</span>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 pb-16 md:pb-24 w-full">
      <SectionReveal>
        <p class="text-brand-orange text-xs tracking-[0.3em] uppercase font-bold mb-4">Speaking Request</p>
        <h1 class="text-5xl md:text-8xl font-display uppercase tracking-tight text-white leading-[0.85] mb-6">
          Invite <br class="hidden md:block" />
          <span class="text-brand-orange">Julian.</span>
        </h1>
      </SectionReveal>
      <SectionReveal delay={200}>
        <p class="text-lg text-zinc-400 font-light max-w-xl">
          Thank you for considering Julian for your event. Please share a few details below so we can learn more about your vision and how we can best serve your community.
        </p>
      </SectionReveal>
    </div>
  </section>

  <!-- ═══════════════ BOOKING FORM ═══════════════ -->
  <section class="py-24 md:py-32 px-6 md:px-12 max-w-4xl mx-auto">
    <form id="booking-form" class="space-y-16">

      <!-- About You -->
      <div>
        <SectionReveal>
          <h2 class="text-3xl md:text-4xl font-display uppercase tracking-tight mb-2">About You</h2>
          <div class="w-12 h-1 bg-brand-orange mb-8"></div>
        </SectionReveal>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <SectionReveal delay={50}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Your Name *</label>
              <input type="text" name="name" required class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Full name" />
            </div>
          </SectionReveal>
          <SectionReveal delay={100}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Church / Organization *</label>
              <input type="text" name="organization" required class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Organization name" />
            </div>
          </SectionReveal>
          <SectionReveal delay={150}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Your Role</label>
              <input type="text" name="role" class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Pastor, Leader, Coach, etc." />
            </div>
          </SectionReveal>
          <SectionReveal delay={200}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Email *</label>
              <input type="email" name="email" required class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="you@church.org" />
            </div>
          </SectionReveal>
          <SectionReveal delay={250}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Phone Number</label>
              <input type="tel" name="phone" class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="(555) 000-0000" />
            </div>
          </SectionReveal>
        </div>
      </div>

      <!-- About the Event -->
      <div>
        <SectionReveal>
          <h2 class="text-3xl md:text-4xl font-display uppercase tracking-tight mb-2">About the Event</h2>
          <div class="w-12 h-1 bg-brand-orange mb-8"></div>
        </SectionReveal>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <SectionReveal delay={50}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Event Name *</label>
              <input type="text" name="event_name" required class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Event name" />
            </div>
          </SectionReveal>
          <SectionReveal delay={100}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Type of Event *</label>
              <select name="event_type" required class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors text-zinc-900">
                <option value="" disabled selected>Select event type</option>
                {eventTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>
          </SectionReveal>
          <SectionReveal delay={150}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Event Date(s) *</label>
              <input type="text" name="event_date" required class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Date or date range" />
            </div>
          </SectionReveal>
          <SectionReveal delay={200}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Location (City, State)</label>
              <input type="text" name="location" class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="City, State" />
            </div>
          </SectionReveal>
          <SectionReveal delay={250} class="md:col-span-2">
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Who will be in the room?</label>
              <input type="text" name="audience" class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Students, adults, leaders, athletes, etc." />
            </div>
          </SectionReveal>
        </div>
      </div>

      <!-- Heart of the Event -->
      <div>
        <SectionReveal>
          <h2 class="text-3xl md:text-4xl font-display uppercase tracking-tight mb-2">Heart of the Event</h2>
          <div class="w-12 h-1 bg-brand-orange mb-8"></div>
        </SectionReveal>

        <div class="space-y-6">
          <SectionReveal delay={50}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">What is your heart or goal for this event?</label>
              <textarea name="event_goal" rows="4" class="w-full bg-transparent border-2 border-zinc-300 p-4 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors resize-none placeholder-zinc-400" placeholder="Tell us about your vision..."></textarea>
            </div>
          </SectionReveal>
          <SectionReveal delay={100}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">What do you feel your people need most right now?</label>
              <textarea name="people_need" rows="4" class="w-full bg-transparent border-2 border-zinc-300 p-4 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors resize-none placeholder-zinc-400" placeholder="What is God placing on your heart?"></textarea>
            </div>
          </SectionReveal>
        </div>
      </div>

      <!-- Logistics & Budget -->
      <div>
        <SectionReveal>
          <h2 class="text-3xl md:text-4xl font-display uppercase tracking-tight mb-2">Logistics &amp; Budget</h2>
          <div class="w-12 h-1 bg-brand-orange mb-8"></div>
        </SectionReveal>

        <div class="space-y-8">
          <SectionReveal delay={50}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-4">Speaking Focus</label>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {speakingFocus.map((focus) => (
                  <label class="flex items-center gap-3 p-4 border border-zinc-200 hover:border-brand-orange transition-colors cursor-pointer group">
                    <input type="checkbox" name="speaking_focus" value={focus} class="w-4 h-4 accent-brand-orange" />
                    <span class="text-sm font-light group-hover:text-brand-orange transition-colors">{focus}</span>
                  </label>
                ))}
              </div>
            </div>
          </SectionReveal>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <SectionReveal delay={100}>
              <div>
                <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Will travel be required? Nearest airport?</label>
                <input type="text" name="travel" class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors placeholder-zinc-400" placeholder="Yes / No — nearest airport" />
              </div>
            </SectionReveal>
            <SectionReveal delay={150}>
              <div>
                <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-2">Will travel and lodging be provided?</label>
                <select name="lodging" class="w-full bg-transparent border-b-2 border-zinc-300 py-3 text-lg font-light focus:border-brand-orange focus:outline-none transition-colors">
                  <option value="" disabled selected>Select</option>
                  <option value="yes">Yes</option>
                  <option value="no">No</option>
                  <option value="partial">Partial</option>
                  <option value="tbd">To be discussed</option>
                </select>
              </div>
            </SectionReveal>
          </div>

          <SectionReveal delay={200}>
            <div>
              <label class="block text-xs tracking-[0.2em] uppercase font-bold text-zinc-500 mb-4">Budget Range</label>
              <div class="flex flex-wrap gap-3">
                {budgetRanges.map((range) => (
                  <label class="flex items-center gap-2 px-5 py-3 border border-zinc-200 hover:border-brand-orange transition-colors cursor-pointer group">
                    <input type="radio" name="budget" value={range} class="accent-brand-orange" />
                    <span class="text-sm font-light group-hover:text-brand-orange transition-colors">{range}</span>
                  </label>
                ))}
              </div>
            </div>
          </SectionReveal>
        </div>
      </div>

      <!-- Submit -->
      <SectionReveal>
        <div class="pt-8 border-t border-zinc-200">
          <button type="submit" class="w-full md:w-auto px-16 py-5 bg-black text-white font-bold tracking-[0.2em] uppercase hover:bg-brand-orange transition-colors duration-300 text-lg">
            Submit Request
          </button>
          <p class="text-sm text-zinc-400 mt-4 font-light">
            We take every invitation seriously and prayerfully consider each opportunity. Our team will follow up with you soon.
          </p>
        </div>
      </SectionReveal>
    </form>
  </section>

  <!-- ═══════════════ CONFIRMATION MESSAGE (hidden by default) ═══════════════ -->
  <div id="form-success" class="hidden fixed inset-0 bg-black/90 z-50 flex items-center justify-center p-6">
    <div class="bg-white max-w-lg w-full p-12 text-center">
      <div class="w-16 h-16 bg-brand-orange mx-auto mb-6 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <h3 class="text-3xl font-display uppercase tracking-tight mb-4">Request Received</h3>
      <p class="text-zinc-600 font-light mb-8">
        Thank you for reaching out. We take every invitation seriously and prayerfully consider each opportunity. Our team will follow up with you soon.
      </p>
      <a href="/" class="inline-block px-8 py-3 bg-black text-white font-bold tracking-[0.15em] uppercase hover:bg-brand-orange transition-colors text-sm">
        Back to Home
      </a>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('booking-form');
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // In production, this would submit to an API endpoint
    success?.classList.remove('hidden');
  });
</script>
