---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CtaMosaic from '../components/CtaMosaic.astro';
import Marquee from '../components/Marquee.astro';
import SectionReveal from '../components/SectionReveal.astro';

const videoPlaceholders = [
  { title: "Featured Speaking Clip", category: "Featured" },
  { title: "Church Message Clip", category: "Church", video: "/images/preaching-clip.mp4" },
  { title: "Youth Event / Camp Clip", category: "Youth" },
  { title: "Conference Clip", category: "Conference" },
  { title: "FCA / Athlete Talk", category: "Athletics" },
  { title: "Short-Form Teaching", category: "Social" },
];

const socials = [
  { platform: "TikTok", handle: "@iamjuliandismute", href: "https://www.tiktok.com/@iamjuliandismute", desc: "Quick hits of truth. Raw, unfiltered, no fluff." },
  { platform: "YouTube", handle: "@julianspeakslife", href: "https://www.youtube.com/@julianspeakslife", desc: "Full messages, teaching series, and a look behind the scenes." },
  { platform: "Instagram", handle: "@iamjuliandismute", href: "https://www.instagram.com/iamjuliandismute/", desc: "Daily encouragement, reels, and real community." },
  { platform: "Instagram — Wildfire", handle: "@wildfire_dsm", href: "https://www.instagram.com/wildfire_dsm", desc: "The gathering built for encounter. Worship, word, and revival." },
  { platform: "Facebook", handle: "Julian Dismute", href: "https://www.facebook.com/st.julian.dismute/", desc: "Longer content, event updates, and what's happening in the ministry." },
];
---

<BaseLayout title="Media — Julian Dismute">
  <Nav dark />

  <!-- ═══════════════ PAGE HERO ═══════════════ -->
  <section class="relative min-h-[60vh] flex items-end pt-28 bg-black overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/DSC_0694.jpeg"
        alt="Event stage"
        class="w-full h-full object-cover opacity-25 grayscale"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 pb-16 md:pb-24 w-full">
      <SectionReveal>
        <p class="text-brand-gold text-xs tracking-[0.3em] uppercase font-bold mb-4">Media</p>
        <h1 class="text-5xl md:text-8xl lg:text-9xl font-display uppercase tracking-tight text-white leading-[0.85] mb-6">
          See the message. <br class="hidden md:block" />
          <span class="text-brand-gold">Experience</span> <br class="hidden md:block" />
          the impact.
        </h1>
      </SectionReveal>
      <SectionReveal delay={200}>
        <p class="text-lg md:text-xl text-zinc-400 font-light max-w-2xl">
          Julian brings the same fire whether it's a stage, a camera, or a conversation — real talk, real truth, real Christ.
        </p>
      </SectionReveal>
    </div>
  </section>

  <Marquee words={['WATCH', 'LISTEN', 'ENGAGE', 'SHARE', 'TRANSFORM']} />

  <!-- ═══════════════ VIDEO GRID ═══════════════ -->
  <section class="py-24 md:py-32 px-6 md:px-12 max-w-7xl mx-auto">
    <SectionReveal>
      <h2 class="text-5xl md:text-7xl font-display uppercase tracking-tight mb-4">Watch</h2>
      <p class="text-lg text-zinc-500 font-light max-w-xl mb-16">
        Featured clips from speaking engagements, events, and digital ministry.
      </p>
    </SectionReveal>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {videoPlaceholders.map((video, idx) => (
        <SectionReveal delay={idx * 80}>
          <div class="group relative aspect-video bg-zinc-900 overflow-hidden">
            {video.video ? (
              <video
                src={video.video}
                controls
                preload="metadata"
                playsinline
                class="absolute inset-0 w-full h-full object-cover bg-black"
              ></video>
            ) : (
              <>
                <!-- Placeholder pattern -->
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-800 to-zinc-950"></div>

                <!-- Play button -->
                <div class="absolute inset-0 flex items-center justify-center z-10">
                  <div class="w-16 h-16 bg-brand-gold flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  </div>
                </div>

                <!-- Hover overlay -->
                <div class="absolute inset-0 bg-brand-gold/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              </>
            )}

            <!-- Label -->
            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/80 to-transparent z-10 pointer-events-none">
              <span class="text-brand-gold text-[10px] tracking-[0.2em] uppercase font-bold">{video.category}</span>
              <h3 class="text-white font-display text-xl uppercase tracking-tight">{video.title}</h3>
            </div>
          </div>
        </SectionReveal>
      ))}
    </div>

    <SectionReveal delay={500}>
      <p class="text-center text-zinc-400 text-sm mt-8 italic">
        Video content coming soon. Check back for featured speaking clips and ministry moments.
      </p>
    </SectionReveal>
  </section>

  <!-- ═══════════════ PHOTO GALLERY ═══════════════ -->
  <section class="bg-black py-16 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <SectionReveal>
        <h2 class="text-4xl md:text-6xl font-display uppercase tracking-tight text-white mb-12">Gallery</h2>
      </SectionReveal>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <SectionReveal delay={0}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/IMG_12.png" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={80}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/DSC_0629.JPG" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={160}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/fkdgsdf.kgmlkfgjldk.JPG" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={240}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/dsfasdfl;das.png" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={320}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/C14A3117.JPG" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={400}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/DSC_0740.JPG" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={480}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/IMG_8827.JPG" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
        <SectionReveal delay={560}>
          <div class="aspect-square overflow-hidden">
            <img src="/images/DSC_8353.JPG" alt="Ministry moment" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-500" loading="lazy" />
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ═══════════════ SOCIAL PLATFORMS ═══════════════ -->
  <section class="bg-zinc-950 text-white py-24 md:py-32 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <SectionReveal>
        <h2 class="text-5xl md:text-7xl font-display uppercase tracking-tight mb-4">Connect</h2>
        <p class="text-lg text-zinc-400 font-light max-w-xl mb-16">
          Follow along for truth, teaching, and real community — wherever you scroll.
        </p>
      </SectionReveal>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {socials.map((social, idx) => (
          <SectionReveal delay={idx * 100}>
            <a href={social.href} target="_blank" rel="noopener noreferrer" class="group block border border-zinc-800 p-8 md:p-10 hover:border-brand-gold transition-all duration-300">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <h3 class="text-2xl md:text-3xl font-display uppercase tracking-tight group-hover:text-brand-gold transition-colors">{social.platform}</h3>
                  <span class="text-zinc-500 text-sm">{social.handle}</span>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-600 group-hover:text-brand-gold group-hover:translate-x-1 group-hover:-translate-y-1 transition-all"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </div>
              <p class="text-zinc-500 font-light">{social.desc}</p>
            </a>
          </SectionReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA ═══════════════ -->
  <section class="bg-black text-white py-24 md:py-32 px-6 md:px-12 text-center relative overflow-hidden">
    <CtaMosaic />
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.03] overflow-hidden z-[1]">
      <span class="text-[14rem] md:text-[20rem] font-display text-white whitespace-nowrap leading-none">MEDIA</span>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <SectionReveal>
        <h2 class="text-4xl md:text-6xl font-display uppercase tracking-tight mb-6 leading-tight">
          Want Julian at <span class="text-brand-gold">your event?</span>
        </h2>
      </SectionReveal>
      <SectionReveal delay={200}>
        <a href="/booking" class="inline-block px-12 py-5 bg-brand-gold text-white font-bold tracking-[0.2em] uppercase hover:bg-brand-gold-dark transition-colors mt-4">
          Book Julian
        </a>
      </SectionReveal>
    </div>
  </section>

  <Footer />
</BaseLayout>
