---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Marquee from '../components/Marquee.astro';
import SectionReveal from '../components/SectionReveal.astro';
---

<BaseLayout title="Ministry — Julian Dismute">
  <Nav dark />

  <!-- ═══════════════ PAGE HERO ═══════════════ -->
  <section class="relative min-h-[70vh] flex items-end pt-28 bg-black overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/IMG_12.png"
        alt="Worship gathering"
        class="w-full h-full object-cover opacity-30 grayscale"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 pb-16 md:pb-24 w-full">
      <SectionReveal>
        <p class="text-brand-orange text-xs tracking-[0.3em] uppercase font-bold mb-4">Ministry</p>
        <h1 class="text-5xl md:text-8xl lg:text-9xl font-display uppercase tracking-tight text-white leading-[0.85] mb-6">
          A movement for <br class="hidden md:block" />
          conviction <br class="hidden md:block" />
          <span class="text-brand-orange">&amp; revival.</span>
        </h1>
      </SectionReveal>
    </div>
  </section>

  <Marquee words={['FAITH THAT IS REAL', 'COMMUNITY THAT IS STRONG', 'OBEDIENCE THAT IS COURAGEOUS']} />

  <!-- ═══════════════ MINISTRY INTRO ═══════════════ -->
  <section class="py-24 md:py-32 px-6 md:px-12 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">
      <div class="md:col-span-5 md:sticky md:top-32">
        <SectionReveal direction="left">
          <h2 class="text-5xl md:text-7xl font-display uppercase tracking-tight leading-none mb-6">
            Not <br />routine <br />church.
          </h2>
          <div class="brand-rule mb-6"></div>
          <p class="text-xl font-display uppercase tracking-wide text-brand-orange">This is revival.</p>
        </SectionReveal>
      </div>

      <div class="md:col-span-7 space-y-8 text-lg font-light text-zinc-600 leading-relaxed">
        <SectionReveal>
          <p>
            Blaze Collective exists because too many believers are coasting — and it's time to wake up.
          </p>
        </SectionReveal>
        <SectionReveal delay={100}>
          <p>
            In a culture that's made faith comfortable and convenient, this ministry is here to light a fire — to build spaces where people take their walk with God seriously and actually hold each other to it.
          </p>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ═══════════════ BLAZE COLLECTIVE ═══════════════ -->
  <section class="bg-zinc-950 text-white py-24 md:py-32 px-6 md:px-12 relative overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-[0.03] overflow-hidden">
      <span class="text-[10rem] md:text-[18rem] font-display text-white whitespace-nowrap leading-none">BLAZE</span>
    </div>

    <div class="max-w-7xl mx-auto relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <SectionReveal>
            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-6">
              <img src="/images/blaze-logo-white.png" alt="Blaze Collective" class="h-12 sm:h-16 md:h-24 w-auto" />
              <h2 class="text-4xl sm:text-5xl md:text-7xl font-display uppercase tracking-tight">Blaze Collective</h2>
            </div>
          </SectionReveal>

          <SectionReveal delay={100}>
            <p class="text-lg text-zinc-400 font-light leading-relaxed mb-8">
              Blaze Collective is a grassroots community of believers who are hungry for more. Not a brand — a brotherhood and sisterhood built on the conviction that following Jesus costs you everything, and it's worth every bit of it.
            </p>
          </SectionReveal>

          <div class="space-y-4">
            {[
              { value: "Faith that is real", desc: "No performance. No comfort zone. Just real." },
              { value: "Community that is strong", desc: "Accountability, truth, and love — the kind that tells you the hard stuff too." },
              { value: "Obedience that is courageous", desc: "Doing what God says even when it costs you." },
            ].map((item, idx) => (
              <SectionReveal delay={200 + idx * 100}>
                <div class="flex items-start gap-4 p-6 border border-zinc-800 hover:border-brand-orange transition-colors duration-300">
                  <div class="w-2 h-2 bg-brand-orange rounded-full mt-2 shrink-0"></div>
                  <div>
                    <h3 class="text-lg font-bold uppercase tracking-wide text-white">{item.value}</h3>
                    <p class="text-zinc-500 font-light mt-1">{item.desc}</p>
                  </div>
                </div>
              </SectionReveal>
            ))}
          </div>
        </div>

        <SectionReveal direction="right">
          <div class="relative overflow-hidden aspect-[4/5] group">
            <img
              src="/images/DSC_0740.JPG"
              alt="Community gathering"
              class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-100"
              loading="lazy"
            />
            <div class="absolute bottom-0 right-0 w-20 h-20 border-r-4 border-b-4 border-brand-orange"></div>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ═══════════════ WILDFIRE ═══════════════ -->
  <section class="py-24 md:py-32 px-6 md:px-12 max-w-7xl mx-auto">
    <div class="flex flex-col gap-16">
      <!-- Landscape photo spanning full width -->
      <SectionReveal>
        <div class="relative overflow-hidden aspect-[4/3] md:aspect-[21/9] group">
          <img
            src="/images/IMG_13.png"
            alt="Wildfire gathering"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
            loading="lazy"
          />
          <div class="absolute top-0 left-0 w-16 h-16 border-t-4 border-l-4 border-brand-orange"></div>
        </div>
      </SectionReveal>

      <!-- Text content below -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <div>
          <SectionReveal>
            <h2 class="text-5xl md:text-7xl font-display uppercase tracking-tight mb-6">
              Wildfire
            </h2>
            <div class="brand-rule mb-8"></div>
          </SectionReveal>

          <SectionReveal delay={100}>
            <p class="text-lg font-light text-zinc-600 leading-relaxed mb-6">
              Wildfire is a revival gathering born out of Blaze Collective. It started in 2024 as a simple step of obedience — and God turned it into something people keep coming back to.
            </p>
          </SectionReveal>

          <SectionReveal delay={200}>
            <p class="text-lg font-light text-zinc-600 leading-relaxed">
              Worship. The Word. And a straight call to go deeper. No hype. No production. Just people hungry for God and ready to respond.
            </p>
          </SectionReveal>
        </div>

        <SectionReveal delay={300}>
          <div class="p-8 bg-black text-white border-l-4 border-brand-orange h-fit">
            <p class="text-xl font-display uppercase tracking-wide mb-2 text-brand-orange">The reality:</p>
            <p class="text-lg font-medium leading-snug">
              People don't just attend. They respond. This is not routine church. This is revival.
            </p>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA ═══════════════ -->
  <section class="bg-brand-orange text-white py-24 md:py-32 px-6 md:px-12 text-center relative overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-10 overflow-hidden">
      <span class="text-[14rem] md:text-[20rem] font-display text-white whitespace-nowrap leading-none">REVIVAL</span>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto">
      <SectionReveal>
        <h2 class="text-4xl md:text-6xl font-display uppercase tracking-tight mb-6 leading-tight">
          Join the movement.
        </h2>
        <p class="text-xl text-white/90 font-light mb-10 max-w-xl mx-auto">
          Whether you want to bring Julian to speak, partner in ministry, or just connect — we'd love to hear from you.
        </p>
      </SectionReveal>
      <SectionReveal delay={200}>
        <a href="/booking" class="inline-block px-12 py-5 bg-black text-white font-bold tracking-[0.2em] uppercase hover:bg-zinc-900 transition-colors">
          Get in Touch
        </a>
      </SectionReveal>
    </div>
  </section>

  <Footer />
</BaseLayout>
