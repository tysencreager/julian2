---
const HERO_IMAGES = [
  "https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&q=80&w=600",
  "https://images.unsplash.com/photo-1478147427282-58a87a120781?auto=format&fit=crop&q=80&w=600",
  "https://images.unsplash.com/photo-1438283173091-5dbf5c5a3206?auto=format&fit=crop&q=80&w=600",
  "https://images.unsplash.com/photo-1544427920-c49ccfaf8c56?auto=format&fit=crop&q=80&w=600",
  "https://images.unsplash.com/photo-1511632765486-a01980e01a18?auto=format&fit=crop&q=80&w=600",
  "https://images.unsplash.com/photo-1528605248644-14dd04022da1?auto=format&fit=crop&q=80&w=600",
];
const COLORS = ['bg-orange-600', 'bg-zinc-900', 'bg-black', 'bg-orange-500'];
---

<div class="absolute inset-0 z-0" id="hero-mosaic">
  <div class="absolute inset-0 grid grid-cols-4 md:grid-cols-6 grid-rows-6 md:grid-rows-4 gap-0 opacity-50" id="mosaic-grid">
    {Array.from({ length: 24 }).map((_, i) => (
      <div class="mosaic-cell w-full h-full relative overflow-hidden bg-black transition-all duration-500" data-index={i}>
      </div>
    ))}
  </div>

  <!-- Vignette overlays -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,black_80%)]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black/20"></div>
</div>

<script define:vars={{ HERO_IMAGES, COLORS }}>
  function initMosaic() {
    const cells = document.querySelectorAll('.mosaic-cell');
    if (!cells.length) return;

    function randomizeCell(cell) {
      const isImage = Math.random() > 0.4;
      cell.innerHTML = '';
      cell.className = 'mosaic-cell w-full h-full relative overflow-hidden transition-all duration-500';

      if (isImage) {
        cell.classList.add('bg-black');
        const img = document.createElement('img');
        img.src = HERO_IMAGES[Math.floor(Math.random() * HERO_IMAGES.length)];
        img.alt = '';
        img.className = 'absolute inset-0 w-full h-full object-cover grayscale mix-blend-screen opacity-70';
        img.loading = 'lazy';
        cell.appendChild(img);
      } else {
        const color = COLORS[Math.floor(Math.random() * COLORS.length)];
        cell.classList.add(color);
      }
    }

    cells.forEach(randomizeCell);

    setInterval(() => {
      const numChanges = Math.floor(Math.random() * 3) + 2;
      for (let i = 0; i < numChanges; i++) {
        const idx = Math.floor(Math.random() * cells.length);
        randomizeCell(cells[idx]);
      }
    }, 400);
  }

  initMosaic();
</script>
