---
const HERO_IMAGES = [
  "/images/0M4A9206.JPG",
  "/images/C14A3117.JPG",
  "/images/DSC_0629.JPG",
  "/images/DSC_0740.JPG",
  "/images/DSC_8353.JPG",
  "/images/IMG_1920.JPG",
  "/images/IMG_8820.JPG",
  "/images/IMG_19.JPG",
  "/images/DSC_7859.jpg",
  "/images/IMG_4449.JPG",
];
const COLORS = ['bg-brand-gold', 'bg-zinc-900', 'bg-black', 'bg-zinc-800'];
---

<div class="absolute inset-0 z-0" id="hero-mosaic">
  <div class="absolute inset-0 grid grid-cols-4 md:grid-cols-6 grid-rows-6 md:grid-rows-4 gap-0 opacity-60" id="mosaic-grid">
    {Array.from({ length: 24 }).map((_, i) => (
      <div class="mosaic-cell w-full h-full relative overflow-hidden bg-black" data-index={i}>
      </div>
    ))}
  </div>

  <!-- Vignette overlays — softened to let photos breathe -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_10%,black_85%)]"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-black/10"></div>
</div>

<script define:vars={{ HERO_IMAGES, COLORS }}>
  function initMosaic() {
    const cells = document.querySelectorAll('.mosaic-cell');
    if (!cells.length) return;

    // Pre-load images so swaps are instant
    HERO_IMAGES.forEach((src) => {
      const img = new Image();
      img.src = src;
    });

    function randomizeCell(cell) {
      const isImage = Math.random() > 0.4;
      cell.innerHTML = '';
      cell.className = 'mosaic-cell w-full h-full relative overflow-hidden';

      if (isImage) {
        cell.classList.add('bg-black');
        const img = document.createElement('img');
        img.src = HERO_IMAGES[Math.floor(Math.random() * HERO_IMAGES.length)];
        img.alt = '';
        img.className = 'absolute inset-0 w-full h-full object-cover grayscale opacity-60';
        img.loading = 'eager';
        cell.appendChild(img);
      } else {
        const color = COLORS[Math.floor(Math.random() * COLORS.length)];
        cell.classList.add(color);
      }
    }

    cells.forEach(randomizeCell);

    // Gentler animation cycle — fewer DOM swaps, longer intervals
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const interval = isMobile ? 2500 : 900;

    setInterval(() => {
      const idx = Math.floor(Math.random() * cells.length);
      const cell = cells[idx];
      cell.style.opacity = '0';
      setTimeout(() => {
        randomizeCell(cell);
        cell.style.opacity = '1';
      }, 400);
    }, interval);
  }

  // Use requestIdleCallback so mosaic doesn't block first paint
  if ('requestIdleCallback' in window) {
    requestIdleCallback(initMosaic);
  } else {
    setTimeout(initMosaic, 100);
  }
</script>

<style>
  .mosaic-cell {
    transition: opacity 0.5s ease-in-out;
  }
</style>
