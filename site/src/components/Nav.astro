---
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
const currentPath = Astro.url.pathname;

const links = [
  { href: '/about', label: 'About' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/ministry', label: 'Ministry' },
  { href: '/media', label: 'Media' },
  { href: '/booking', label: 'Book Julian' },
];
---

<nav id="main-nav" class="fixed w-full z-50 transition-all duration-500 py-6 md:py-8" data-dark={dark}>
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between items-center">
    <a href="/" class="hover:opacity-80 transition-opacity">
      <img src="/images/JSL LOGO.png" alt="JSL Logo" class="h-10 md:h-12 w-auto" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center space-x-8">
      {links.slice(0, -1).map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-medium text-xs tracking-[0.2em] uppercase transition-colors hover:text-brand-orange",
            currentPath === link.href ? "text-brand-orange" : ""
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/booking"
        class="px-6 py-3 bg-brand-orange text-white font-bold text-xs tracking-[0.15em] uppercase rounded-none hover:bg-orange-700 transition-all inline-flex items-center gap-2"
      >
        Book Julian
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button id="mobile-toggle" class="lg:hidden flex flex-col gap-1.5 w-8 h-8 items-center justify-center" aria-label="Toggle menu">
      <span class="block w-6 h-0.5 bg-current transition-all duration-300 origin-center" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-current transition-all duration-300" id="bar2"></span>
      <span class="block w-4 h-0.5 bg-current transition-all duration-300 origin-center ml-auto" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed inset-0 bg-black z-40 flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-500 lg:hidden">
    <div class="flex flex-col items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-white text-3xl font-display tracking-wider uppercase hover:text-brand-orange transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const isDark = nav?.dataset.dark !== undefined && nav?.dataset.dark !== 'false';
  let menuOpen = false;

  function updateNav() {
    if (!nav) return;
    const scrolled = window.scrollY > 50;

    if (menuOpen) {
      nav.classList.add('text-white');
      nav.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm', 'py-4');
      return;
    }

    if (scrolled) {
      nav.classList.add('bg-white/90', 'backdrop-blur-md', 'shadow-sm');
      nav.classList.remove('py-6', 'md:py-8');
      nav.classList.add('py-4');
      nav.classList.remove('text-white');
    } else {
      nav.classList.remove('bg-white/90', 'backdrop-blur-md', 'shadow-sm', 'py-4');
      nav.classList.add('py-6', 'md:py-8');
      if (isDark) {
        nav.classList.add('text-white');
      } else {
        nav.classList.remove('text-white');
      }
    }
  }

  toggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menu) {
      menu.classList.toggle('opacity-0', !menuOpen);
      menu.classList.toggle('pointer-events-none', !menuOpen);
    }
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');
    if (menuOpen) {
      bar1?.classList.add('rotate-45', 'translate-y-1');
      bar2?.classList.add('opacity-0');
      bar3?.classList.add('-rotate-45', '-translate-y-2', 'w-6');
      nav?.classList.add('text-white');
    } else {
      bar1?.classList.remove('rotate-45', 'translate-y-1');
      bar2?.classList.remove('opacity-0');
      bar3?.classList.remove('-rotate-45', '-translate-y-2', 'w-6');
      updateNav();
    }
  });

  window.addEventListener('scroll', updateNav);
  updateNav();
</script>
