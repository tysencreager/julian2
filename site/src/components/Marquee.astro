---
interface Props {
  words?: string[];
  class?: string;
}
const { words = ['SURRENDER', 'CONVICTION', 'COURAGE', 'OBEDIENCE', 'FAITH'], class: className = '' } = Astro.props;
const repeated = [...words, ...words, ...words, ...words];
---

<div class:list={["bg-brand-gold text-white py-4 overflow-hidden flex whitespace-nowrap select-none", className]}>
  <div class="animate-marquee inline-flex items-center shrink-0">
    {repeated.map((word) => (
      <span class="font-sans text-sm md:text-base font-medium tracking-[0.25em] uppercase px-6 inline-flex items-center gap-6">
        {word}
        <span class="text-brand-gold-light text-xs">&bull;</span>
      </span>
    ))}
  </div>
  <div class="animate-marquee inline-flex items-center shrink-0" aria-hidden="true">
    {repeated.map((word) => (
      <span class="font-sans text-sm md:text-base font-medium tracking-[0.25em] uppercase px-6 inline-flex items-center gap-6">
        {word}
        <span class="text-brand-gold-light text-xs">&bull;</span>
      </span>
    ))}
  </div>
</div>
