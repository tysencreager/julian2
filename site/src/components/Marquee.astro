---
interface Props {
  words?: string[];
  class?: string;
}
const { words = ['SURRENDER', 'CONVICTION', 'COURAGE', 'OBEDIENCE', 'FAITH'], class: className = '' } = Astro.props;
const repeated = [...words, ...words, ...words, ...words];
---

<div class:list={["bg-brand-orange text-white py-4 overflow-hidden flex whitespace-nowrap select-none", className]}>
  <div class="animate-marquee inline-flex items-center shrink-0">
    {repeated.map((word) => (
      <span class="font-display text-2xl md:text-3xl tracking-wider px-4 inline-flex items-center gap-4">
        {word}
        <span class="text-orange-300 text-lg">&bull;</span>
      </span>
    ))}
  </div>
  <div class="animate-marquee inline-flex items-center shrink-0" aria-hidden="true">
    {repeated.map((word) => (
      <span class="font-display text-2xl md:text-3xl tracking-wider px-4 inline-flex items-center gap-4">
        {word}
        <span class="text-orange-300 text-lg">&bull;</span>
      </span>
    ))}
  </div>
</div>
