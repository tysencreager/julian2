---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Christian Speaker & Minister — Calling this generation to follow Jesus with everything. No compromise, no holding back." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script type="text/javascript" src="https://www.bugherd.com/sidebarv2.js?apikey=qbshpyikmtb45vmthkzlnq" async="true"></script>
  </head>
  <body>
    <div class="grain-overlay"></div>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
